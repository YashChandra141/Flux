{
  "name": "flux",
  "version": "0.1.0",
  "description": "Flux — an AI coding agent in your terminal (like OpenCode / Codex / Claude Code), built on Bun + the Vercel AI SDK.",
  "type": "module",
  "bin": {
    "flux": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "compile": "bun build src/cli.ts --compile --outfile flux"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@clack/prompts": "^0.11.0",
    "ai": "^5.0.0",
    "chalk": "^5.3.0",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "typescript": "^5.6.0"
  }
}
