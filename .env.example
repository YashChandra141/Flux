# Pick a provider by setting its API key, then (optionally) choose a model.
# The agent auto-selects a provider based on which key is present.
# Priority when multiple are set: FLUX_PROVIDER > nvidia > anthropic > openai > google.

# Force a specific provider regardless of which keys exist (nvidia | anthropic | openai | google)
# FLUX_PROVIDER=nvidia

# Override the model id for the selected provider.
# NVIDIA NIM models:
#   meta/llama-3.3-70b-instruct           (default, reliable tool calling)
#   moonshotai/kimi-k2.6                  (kimi - agentic coding / tool use)
#   z-ai/glm4.7                           (glm - agentic coding, reasoning)
#   qwen/qwen3-235b-a22b                  (qwen - large MoE, tool calling)
#   qwen/qwen2.5-coder-32b-instruct       (qwen - coding specialist)
#   minimaxai/minimax-m2.7                (minimax - coding + reasoning)
#   google/gemma-3-27b-it                 (gemma - general; weaker tool use)
#   deepseek-ai/deepseek-v3.1             (strong general + coding)
#   nvidia/llama-3.3-nemotron-super-49b-v1.5
#   mistralai/mistral-nemotron            (built for agentic workflows)
# Free-tier Gemini options: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.0-flash
# FLUX_MODEL=meta/llama-3.3-70b-instruct

# --- Provider API keys ---
# NVIDIA NIM key from build.nvidia.com (starts with "nvapi-")
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
